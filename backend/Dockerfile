FROM golang:1.24-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /server ./cmd/server/

FROM alpine:3.19

RUN addgroup -S app && adduser -S app -G app
COPY --from=builder /server /server
USER app

EXPOSE 8080
CMD ["/server"]
